{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "aibok",
  "version": "0.1.0",
  "identifier": "se.aibok.app",
  "build": {
    "beforeDevCommand": "concurrently --names \"backend,frontend\" --prefix-colors \"blue,cyan\" \"cd backend && .venv/bin/uvicorn main:app --reload --port 8000\" \"vite --port 5173\"",
    "beforeBuildCommand": "vite build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "aibok – Fakturatolk",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
